# GitHub Token（用于数据持久化备份，必须设置）
# 在 https://github.com/settings/tokens 创建一个 classic token，权限勾选 repo
GITHUB_TOKEN=

# 仓库全名（默认 caij97116-stack/zhi-gao）
# GITHUB_REPOSITORY=caij97116-stack/zhi-gao

# 数据存储目录（默认 ./data，Render 有磁盘时设为 /var/data）
# DATA_DIR=/var/data

# 加密密钥（可选，不设置则自动生成并保存到 DATA_DIR/.encryption_key）
# ENCRYPTION_KEY=change-me-to-a-random-32-char-string

# 服务端口
PORT=3001

# Discord OAuth2（用于网页端 Discord 登录，可选）
# 在 https://discord.com/developers/applications → OAuth2 页面获取
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# 回调地址会自动检测，无需手动设置（除非有特殊需求）
# DISCORD_REDIRECT_URI=http://localhost:3001/callback
